{
  "rewrites": [
    { "source": "/", "destination": "/MVP/index.html" },
    { "source": "/prototype.js", "destination": "/MVP/prototype.js" },
    { "source": "/kst/:path*", "destination": "/MVP/kst/:path*" },
    { "source": "/:file(.*\\.html)", "destination": "/MVP/:file" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    }
  ]
}
